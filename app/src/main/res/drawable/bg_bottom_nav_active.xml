<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <gradient
                android:startColor="#46A97CFF"
                android:endColor="#22FF88D8"
                android:angle="0" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#96B18CFF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <gradient
                android:startColor="#1FFFFFFF"
                android:endColor="@android:color/transparent"
                android:angle="90" />
            <corners android:radius="22dp" />
        </shape>
    </item>

</layer-list>