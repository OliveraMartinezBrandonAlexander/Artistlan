<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <gradient
                android:startColor="@color/artistlan_menu_bottombar"
                android:endColor="@color/artistlan_menu_bottombar_2"
                android:angle="90" />
            <corners
                android:topLeftRadius="30dp"
                android:topRightRadius="30dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <stroke
                android:width="1dp"
                android:color="@color/artistlan_menu_stroke" />
        </shape>
    </item>

    <item android:top="1dp">
        <shape>
            <gradient
                android:startColor="#24FFFFFF"
                android:endColor="@android:color/transparent"
                android:angle="90" />
            <corners
                android:topLeftRadius="30dp"
                android:topRightRadius="30dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

</layer-list>