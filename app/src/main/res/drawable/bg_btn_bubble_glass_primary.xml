<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#8F72D9FF"
                android:centerColor="#6673B8FF"
                android:endColor="#4D9E7BFF" />
            <corners android:radius="40dp" />
            <stroke
                android:width="1dp"
                android:color="#66FFFFFF" />
        </shape>
    </item>

    <item
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="34dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#55FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>

</layer-list>