<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <gradient
                android:startColor="@color/artistlan_menu_accent_soft"
                android:endColor="@color/artistlan_menu_accent_secondary_soft"
                android:angle="0" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/artistlan_menu_accent" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>