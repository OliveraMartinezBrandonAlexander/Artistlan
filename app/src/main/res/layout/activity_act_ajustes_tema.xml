<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_account_screen">

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:alpha="0.42"
        android:background="@drawable/bg_glow_purple"
        android:translationX="-55dp"
        android:translationY="-35dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.20"
        android:background="@drawable/bg_glow_soft_white"
        android:translationY="95dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:alpha="0.38"
        android:background="@drawable/bg_glow_pink"
        android:translationX="70dp"
        android:translationY="85dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/themeBtnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_back_bubble"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/regresarimg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/urbanist_bold"
                    android:text="Ajustes visuales"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="26sp" />

                <Button
                    android:id="@+id/themeBtnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn_bubble_glass_secondary"
                    android:text="Reset"
                    android:textAllCaps="false"
                    android:textColor="@color/artistlan_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_form_glass_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Temas predeterminados"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Aplica un preset y luego ajusta detalles manualmente si lo deseas."
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/themePresetsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_form_glass_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vista previa"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Simulación de top bar, drawer, panel, input, botón y navegación inferior."
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_dialog_solid_panel">

                    <View
                        android:id="@+id/previewGlow1"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="start|top"
                        android:alpha="0.55"
                        android:background="@drawable/bg_glow_purple" />

                    <View
                        android:id="@+id/previewGlow2"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="end|bottom"
                        android:alpha="0.38"
                        android:background="@drawable/bg_glow_pink" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/previewTopbar"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:background="#221232" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/previewDrawer"
                                android:layout_width="64dp"
                                android:layout_height="match_parent"
                                android:background="#1A1F2A" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/previewTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ARTISTLAN"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/previewSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Tema aplicado"
                                    android:textColor="#D0D4E6"
                                    android:textSize="12sp" />

                                <LinearLayout
                                    android:id="@+id/previewCard"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_marginTop="8dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_form_glass_panel"
                                    android:orientation="vertical"
                                    android:padding="8dp">

                                    <TextView
                                        android:id="@+id/previewBody"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Tarjeta premium"
                                        android:textColor="#D0D4E6"
                                        android:textSize="12sp" />

                                    <View
                                        android:id="@+id/previewInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="24dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/bg_edittext_bubble" />

                                    <View
                                        android:id="@+id/previewButton"
                                        android:layout_width="72dp"
                                        android:layout_height="20dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/bg_btn_bubble_primary" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:id="@+id/previewBottomBar"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="#1B102B" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_form_glass_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Roles de color"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Toca cualquier color para abrir su selector."
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerThemeSections"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>