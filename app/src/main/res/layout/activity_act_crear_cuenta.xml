<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/CrcLayMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_account_screen"
    tools:context=".Activitys.ActCrearCuenta">

    <View
        android:id="@+id/CrcGlowTop"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:alpha="0.45"
        android:background="@drawable/bg_glow_purple"
        android:translationX="-60dp"
        android:translationY="-40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/CrcGlowCenter"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.22"
        android:background="@drawable/bg_glow_soft_white"
        android:translationY="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/CrcGlowBottom"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:alpha="0.42"
        android:background="@drawable/bg_glow_pink"
        android:translationX="80dp"
        android:translationY="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/CrcScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/CrcLayCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Fuera del panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/CrcBtnRegresar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_back_bubble"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/regresarimg" />

                <TextView
                    android:id="@+id/CrcTxtBrand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/urbanist_bold"
                    android:letterSpacing="0.05"
                    android:text="ARTISTLAN"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="26sp" />

            </LinearLayout>

            <!-- Todo esto ya va dentro del panel -->
            <LinearLayout
                android:id="@+id/CrcFormContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical"
                android:padding="22dp"
                android:background="@drawable/bg_form_glass_panel">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/CrcLottieSide"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/lottie_create_side" />

                    <TextView
                        android:id="@+id/CrcTxtTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="Crea tu cuenta"
                        android:textColor="@color/artistlan_text_primary"
                        android:textSize="24sp" />

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/CrcDividerContainer"
                    android:layout_width="110dp"
                    android:layout_height="6dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp">

                    <View
                        android:id="@+id/CrcDividerBase"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_divider_glow" />

                    <View
                        android:id="@+id/CrcDividerShimmer"
                        android:layout_width="26dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center_vertical"
                        android:alpha="0.95"
                        android:background="@drawable/bg_divider_shimmer" />

                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Completa los datos que se solicitan"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/CrcTxtSeparador2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Los campos con * son obligatorios"
                    android:textColor="#A9C2D7"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/CrcTxtUsuarioMainLbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Usuario   *"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="16sp" />

                <LinearLayout
                    android:id="@+id/CrcLayUsuarioLblGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/CrcTxtUsuarioDescLbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="(este será el nombre que todos podrán visualizar)"
                        android:textColor="#C6D3E6"
                        android:textSize="10sp" />

                </LinearLayout>

                <EditText
                    android:id="@+id/CrcEdtUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="Tamalero2007"
                    android:inputType="textPersonName"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <TextView
                    android:id="@+id/CrcTxtEmailLbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Correo Electrónico  *"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CrcEdtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="ejemplo@gmail.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <TextView
                    android:id="@+id/CrcTxtNombreLbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Nombre completo  *"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CrcEdtNombre"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="Pablito"
                    android:inputType="textPersonName"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <TextView
                    android:id="@+id/CrcTxtTelLbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Teléfono"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CrcEdtTel"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="55XXXXXXXX"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <TextView
                    android:id="@+id/CrcTxtFechaLbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Fecha de Nacimiento  *"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CrcEdtFecha"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="DÍA / MES / AÑO"
                    android:inputType="none"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7"
                    android:textCursorDrawable="@null" />

                <LinearLayout
                    android:id="@+id/CrcLayPassLblGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/CrcTxtPassMainLbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Genera una contraseña segura  *"
                        android:textColor="@color/artistlan_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/CrcTxtPassDescLbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="sans-serif"
                        android:text="(mínimo 8 caracteres, una mayúscula, una minúscula y un número)"
                        android:textColor="#C6D3E6"
                        android:textSize="10sp" />

                </LinearLayout>

                <EditText
                    android:id="@+id/CrcEdtPass"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="Ejemplo2_!"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <TextView
                    android:id="@+id/CrcTxtPassConfLbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Confirmar Contraseña"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CrcEdtPassConf"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="22dp"
                    android:background="@drawable/bg_input_artistlan"
                    android:hint="Ejemplo2_!"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/artistlan_text_primary"
                    android:textColorHint="#9FB1C7" />

                <Button
                    android:id="@+id/CrcBtnCrc"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_btn_bubble_glass_primary"
                    android:elevation="0dp"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="Crear cuenta"
                    android:textAllCaps="false"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="17sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Overlay resultado / espera -->
    <FrameLayout
        android:id="@+id/CrcResultOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#73000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/CrcResultDialog"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp"
            android:background="@drawable/bg_dialog_solid_panel">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/CrcResultLottie"
                android:layout_width="130dp"
                android:layout_height="130dp"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />

            <TextView
                android:id="@+id/CrcResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-black"
                android:text="Resultado"
                android:textColor="@android:color/white"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/CrcResultMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Mensaje"
                android:textColor="#E8EDF7"
                android:textSize="14sp" />

            <Button
                android:id="@+id/CrcResultOk"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_btn_bubble_glass_secondary"
                android:text="Aceptar"
                android:textAllCaps="false"
                android:textColor="@color/artistlan_text_primary"
                android:textSize="16sp" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>