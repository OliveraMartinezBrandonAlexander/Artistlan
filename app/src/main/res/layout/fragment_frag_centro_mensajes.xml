<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".Fragments.FragCentroMensajes">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/artistlan_menu_bg"
        android:stateListAnimator="@null"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/artistlan_menu_bg"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnCentroMensajesAtras"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_back_bubble"
                    android:contentDescription="Regresar"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/regresarimg" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/urbanist_bold"
                    android:maxLines="1"
                    android:text="Centro de mensajes"
                    android:textColor="@color/artistlan_menu_bottombar_2"
                    android:textSize="22sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnCentroMensajesMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_action_outline_soft"
                    android:contentDescription="Más opciones"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/artistlan_bg_mid" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvCentroMensajesResumenContador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pendientes: 0 mensajes no leidos + 0 solicitudes"
                android:textColor="@color/artistlan_menu_icon_active"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_centro_tabs_container"
                android:padding="4dp">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayoutCentroMensajes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:tabBackground="@drawable/bg_centro_tab_item"
                    app:tabIndicatorColor="@android:color/transparent"
                    app:tabIndicatorHeight="0dp"
                    app:tabMode="fixed"
                    app:tabRippleColor="@color/artistlan_menu_accent_soft"
                    app:tabSelectedTextColor="@color/artistlan_menu_text_primary"
                    app:tabTextColor="@color/artistlan_menu_text_secondary" />
            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerCentroMensajes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/artistlan_menu_bg"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
