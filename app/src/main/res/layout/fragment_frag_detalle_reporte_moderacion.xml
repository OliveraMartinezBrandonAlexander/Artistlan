<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    tools:context=".Fragments.FragDetalleReporteModeracion">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/artistlan_menu_stroke_soft" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvTituloPantallaDetalleReporteModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detalle de reporte"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtituloPantallaDetalleReporteModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Consulta la informaci&#243;n completa del reporte y t&#243;malo si sigue pendiente."
                android:textColor="@color/artistlan_menu_text_secondary"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/progressDetalleReporteModeracion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvErrorDetalleReporteModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="#8A2D2D"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/contenedorDetalleReporteModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/artistlan_menu_surface_soft"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/artistlan_menu_stroke_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvIdDetalleReporteModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Reporte #0"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTipoObjetivoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tipo de objetivo: N/A"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTituloObjetivoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Objetivo: Sin t&#237;tulo"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDescripcionObjetivoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Descripci&#243;n del contenido: Sin descripci&#243;n"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/imgObjetivoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginTop="12dp"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/imagencargaobras"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvReportanteDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Reportante: No disponible"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvUsuarioReportadoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Due&#241;o o usuario reportado: No disponible"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMotivoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Motivo: Sin motivo"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescripcionReporteDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Descripci&#243;n del reporte: Sin descripci&#243;n"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvEstadoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Estado: N/A"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPrioridadDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Prioridad: N/A"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvModeradorAsignadoDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Moderador asignado: Sin asignar"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFechaReporteDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Fecha del reporte: No disponible"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFechaInicioRevisionDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Inicio de revisi&#243;n: No disponible"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvAccionResolucionDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Acci&#243;n de resoluci&#243;n:"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvMensajeRespuestaDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Mensaje de respuesta:"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvFechaResolucionDetalleModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Fecha de resoluci&#243;n:"
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnTomarReporteModeracion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/artistlan_secondary"
                    android:text="Tomar reporte"
                    android:textAllCaps="false"
                    android:visibility="gone" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardResolverReporteModeracion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/artistlan_menu_surface_soft"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/artistlan_menu_stroke_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Resolver reporte"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Selecciona la acci&#243;n final y completa la respuesta para cerrar el reporte."
                            android:textColor="@color/artistlan_menu_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Acci&#243;n"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinnerAccionResolverModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Mensaje de respuesta"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etMensajeRespuestaModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="top|start"
                            android:hint="Mensaje para el usuario o reportante"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="3" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Motivo interno"
                            android:textColor="@color/artistlan_menu_text_primary"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etMotivoAccionModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="top|start"
                            android:hint="Motivo interno o explicaci&#243;n de la acci&#243;n"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="3" />

                        <LinearLayout
                            android:id="@+id/contenedorFechaFinSuspensionModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Fecha fin de suspensi&#243;n"
                                android:textColor="@color/artistlan_menu_text_primary"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/etFechaFinSuspensionModeracion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:hint="Fecha fin de suspensi&#243;n (yyyy-MM-dd'T'HH:mm:ss)"
                                android:inputType="text" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnResolverReporteModeracion"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="18dp"
                            android:backgroundTint="@color/artistlan_secondary"
                            android:text="Resolver reporte"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
