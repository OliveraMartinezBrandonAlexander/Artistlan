<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    tools:context=".Fragments.FragMain">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="102dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutMainHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_carousel_card_glass"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/tvMainWelcomeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Bienvenido a Artistlan"
                    android:textAlignment="center"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="27sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/viewWelcomeAccent"
                    android:layout_width="72dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_divider_glow" />

                <TextView
                    android:id="@+id/tvMainWelcomeSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Descubre obras, servicios y talento artístico"
                    android:textAlignment="center"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCarruselFamaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Obras destacadas"
                android:textAlignment="center"
                android:textColor="@color/artistlan_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerCarrusel"
                android:layout_width="match_parent"
                android:layout_height="410dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <LinearLayout
                android:id="@+id/layoutMainFeedSeparator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/viewFeedSeparatorStart"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_divider_glow" />

                <TextView
                    android:id="@+id/tvMainFeedSeparator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_chip_glass"
                    android:paddingStart="13dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="6dp"
                    android:text="Explora más"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/viewFeedSeparatorEnd"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_divider_glow" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeedPublicacionesMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_tarjetatextoobra" />

            <ProgressBar
                android:id="@+id/pbConvocatoriasMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvConvocatoriasMainEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:textColor="@color/artistlan_text_secondary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConvocatoriasMain"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCarruselIzquierdo"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false" />

            <ImageButton
                android:id="@+id/btnCarruselDerecho"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
