<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    tools:context=".Fragments.FragMain">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="102dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutMainHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/bg_card_feed_glass"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/tvMainWelcomeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Bienvenido a Artistlan"
                    android:textAlignment="center"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="27sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMainWelcomeSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Descubre obras, servicios y talento artístico"
                    android:textAlignment="center"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCarruselFamaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                android:text="Carrusel de la fama"
                android:textColor="@color/artistlan_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerCarrusel"
                android:layout_width="match_parent"
                android:layout_height="430dp"
                android:layout_marginTop="6dp"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeedPublicacionesMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_tarjetatextoobra" />

            <ProgressBar
                android:id="@+id/pbConvocatoriasMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvConvocatoriasMainEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:textColor="@color/artistlan_text_secondary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConvocatoriasMain"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCarruselIzquierdo"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false" />

            <ImageButton
                android:id="@+id/btnCarruselDerecho"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
