<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    tools:context=".Fragments.FragMain">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/artistlan_menu_stroke_soft" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="BIENVENIDO A ARTISTLAN"
                android:textColor="@color/artistlan_menu_stroke_soft"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-condensed-medium"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:text="Top del semestre"
                android:textColor="@android:color/darker_gray"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btnCarruselIzquierdo"
                    android:layout_width="40dp"
                    android:layout_height="200dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:src="@drawable/botonizquierdoprincipal"
                    android:scaleType="fitCenter"
                    android:contentDescription="Imagen anterior"/>

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerCarrusel"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_toEndOf="@id/btnCarruselIzquierdo"
                    android:layout_toStartOf="@id/btnCarruselDerecho"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btnCarruselDerecho"
                    android:layout_width="40dp"
                    android:layout_height="200dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:src="@drawable/botonderechoprincipal"
                    android:scaleType="fitCenter"
                    android:contentDescription="Siguiente imagen"/>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:text="Eventos próximos:"
                android:textColor="@color/artistlan_menu_stroke_soft"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <ProgressBar
                android:id="@+id/pbConvocatoriasMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvConvocatoriasMainEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="#555555"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConvocatoriasMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_main_convocatoria" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
