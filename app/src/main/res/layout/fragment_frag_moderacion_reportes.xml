<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    tools:context=".Fragments.FragModeracionReportes">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/artistlan_menu_stroke_soft" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvTituloModeracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moderación"
            android:textColor="@color/artistlan_menu_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtituloModeracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Revisa los reportes enviados por la comunidad."
            android:textColor="@color/artistlan_menu_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/contenedorFiltrosModeracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_artistlan"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerEstadoModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tipo de objetivo"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTipoModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Prioridad"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerPrioridadModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <CheckBox
                android:id="@+id/checkSoloMiosModeracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Solo mis reportes"
                android:textColor="@color/artistlan_menu_text_primary" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressModeracionReportes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvModeracionVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Sin reportes"
            android:textColor="#5E5E5E"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerModeracionReportes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</LinearLayout>
