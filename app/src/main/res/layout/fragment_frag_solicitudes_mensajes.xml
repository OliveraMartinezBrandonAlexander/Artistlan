<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/artistlan_menu_bg"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="6dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:id="@+id/segmentContainerSolicitudes"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_solicitudes_segment_container_mensajes"
        android:padding="4dp">

        <View
            android:id="@+id/segmentIndicatorSolicitudes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_solicitudes_segment_indicator_mensajes" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSolicitudesEnviadas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="ENVIADAS"
                android:textAllCaps="false"
                android:textColor="@color/artistlan_menu_text_secondary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSolicitudesRecibidas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="RECIBIDAS"
                android:textAllCaps="false"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layoutSolicitudesAccionesLocal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnSolicitudesMarcarTodasLeidas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_action_outline_soft"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="Marcar todas leidas"
            android:textColor="@color/artistlan_menu_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSolicitudesRecargar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_action_outline_soft"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="Actualizar"
            android:textColor="@color/artistlan_menu_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSolicitudesMensajes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutSolicitudesVacia"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="30dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:alpha="0.85"
                android:src="@drawable/ic_notificaciones_artistlan" />

            <TextView
                android:id="@+id/tvSolicitudesVaciaTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="No tienes solicitudes pendientes"
                android:textColor="@color/artistlan_menu_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSolicitudesVaciaSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Cuando recibas solicitudes apareceran aqui."
                android:textColor="@color/artistlan_menu_text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressSolicitudesMensajes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
