<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootPublicPerfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    tools:context=".Fragments.FragVerPerfilPublico">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/artistlan_menu_stroke_soft" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPerfilPublico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/artistlan_menu_surface_soft"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:strokeColor="@color/artistlan_menu_stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/imgPerfilPublico"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:background="@drawable/img_redonda"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/fotoperfilprueba"/>

                        <TextView
                            android:id="@+id/tvNombrePublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:text="usuario"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/artistlan_menu_stroke_soft"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDescripcionPublico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Descripción"
                        android:textColor="@color/artistlan_menu_stroke_soft"
                        android:textSize="14sp"
                        android:background="@drawable/bg_input_artistlan"

                        android:padding="12dp"/>

                    <LinearLayout
                        android:id="@+id/expandedInfoPublico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:orientation="vertical"
                        android:background="@drawable/bg_input_artistlan"

                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvNombreCompletoPublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nombre: ---"
                            android:textColor="@color/artistlan_menu_stroke_soft"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvUbicacionPublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Ubicación: ---"
                            android:textColor="@color/artistlan_menu_stroke_soft"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvRedesPublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Redes: ---"
                            android:textColor="@color/artistlan_menu_stroke_soft"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFecNacPublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Fecha: ---"
                            android:textColor="@color/artistlan_menu_stroke_soft"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvCategoriaPublico"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Ocupación: ---"
                            android:textColor="@color/artistlan_menu_stroke_soft"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTabs"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@android:color/transparent"
                android:elevation="0dp"
                android:radius="16dp">

                <FrameLayout
                    android:id="@+id/tabsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_segment_container"
                    android:padding="6dp">

                    <View
                        android:id="@+id/tabIndicator"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:background="@drawable/bg_segment_indicator"
                        />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnTabObras"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="OBRAS"
                            android:textStyle="bold"
                            android:textColor="@color/artistlan_menu_text_primary"/>

                        <TextView
                            android:id="@+id/btnTabServicios"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="SERVICIOS"
                            android:textStyle="bold"
                            android:textColor="@color/artistlan_menu_text_secondary"/>
                    </LinearLayout>

                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPublico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvPublicoVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Sin contenido"
                android:textColor="#5E5E5E"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
