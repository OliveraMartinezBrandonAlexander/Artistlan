<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="152dp"
    android:background="@drawable/bg_drawer_header_artistlan"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <FrameLayout
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:background="@drawable/bg_drawer_avatar"
        android:padding="6dp">

        <ImageView
            android:id="@+id/imgPerfilDrawer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Foto de perfil"
            android:scaleType="centerCrop"
            android:src="@drawable/cuenta" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreDrawer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="Perfil de usuario"
            android:textColor="@color/artistlan_menu_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCorreoDrawer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="demo@artistlan.com"
            android:textColor="@color/artistlan_menu_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtRolDrawer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_drawer_item_selected"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:text="Modo: Artista"
            android:textColor="@color/artistlan_menu_text_on_accent"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>