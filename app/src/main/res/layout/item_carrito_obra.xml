<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/artistlan_menu_surface_soft"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgCarritoObra"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:scaleType="centerCrop"
                android:src="@drawable/imagencargaobras" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCarritoTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="Titulo de obra"
                    android:textColor="@color/artistlan_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCarritoArtista"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:text="Artista: usuario"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvCarritoPrecio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Precio: $ 0.00"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCarritoEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_action_outline_soft"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="Reserva: Pendiente"
                    android:textColor="@color/artistlan_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCarritoReservaDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Reserva hasta: 01/01/2026 12:30"
                    android:textColor="#5A497A"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnCarritoComprar"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:backgroundTint="@color/artistlan_secondary"
                android:text="Comprar"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnCarritoContactar"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D7C4EC"
                android:text="Contactar artista"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnCarritoQuitar"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#EFD2D2"
                android:text="Quitar del carrito"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
