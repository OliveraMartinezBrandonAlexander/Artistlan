<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutHistoriaCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_historia_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvCategoriaHistoriaArte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_historia_chip"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Categoría"
        android:textAllCaps="true"
        android:textColor="@color/artistlan_text_primary"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTituloHistoriaArte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Título"
        android:textColor="@color/artistlan_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvResumenHistoriaArte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Resumen breve"
        android:textColor="@color/artistlan_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvContenidoHistoriaArte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:text="Contenido extendido"
        android:textColor="@color/artistlan_text_primary"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvVerMasHistoriaArte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="Ver más"
        android:textColor="@color/artistlan_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>