<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvMainTituloConvocatoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/artistlan_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMainDescripcionConvocatoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/artistlan_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvMainFechaConvocatoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/artistlan_text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnMainVerMasConvocatoria"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/artistlan_secondary"
            android:text="Saber más"
            android:textAllCaps="false"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>