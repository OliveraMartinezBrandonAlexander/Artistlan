<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_input_artistlan"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <View
        android:id="@+id/roleColorPreview"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="#FF00FF" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/roleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textColor="@color/artistlan_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/roleDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Descripción"
            android:textColor="@color/artistlan_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/roleHex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="#FFFFFFFF"
            android:textColor="#C6D3E6"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>