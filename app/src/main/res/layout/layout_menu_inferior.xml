<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/MenuInferior"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/navCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:contentPadding="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/artistlan_menu_stroke_soft"
        app:strokeWidth="1dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_nav_artistlan"
            android:minHeight="76dp"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            app:itemActiveIndicatorStyle="@style/ArtistlanBottomNavActiveIndicator"
            app:itemIconSize="25dp"
            app:itemIconTint="@color/bottom_nav_item_colors"
            app:itemPaddingTop="8dp"
            app:itemPaddingBottom="4dp"
            app:itemRippleColor="@color/artistlan_menu_accent_soft"
            app:itemTextAppearanceActive="@style/ArtistlanBottomNavTextActive"
            app:itemTextAppearanceInactive="@style/ArtistlanBottomNavTextInactive"
            app:itemTextColor="@color/bottom_nav_text_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_inferior" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>